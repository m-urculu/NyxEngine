{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows x64 (MSVC)",
      "description": "Native Windows build with Visual Studio 2022 + MSVC",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "linux",
      "displayName": "Linux (default compiler)",
      "description": "Local Linux build (e.g. under WSL)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "windows-debug",   "configurePreset": "windows-msvc", "configuration": "Debug" },
    { "name": "windows-release", "configurePreset": "windows-msvc", "configuration": "Release" },
    { "name": "linux",           "configurePreset": "linux" }
  ]
}
